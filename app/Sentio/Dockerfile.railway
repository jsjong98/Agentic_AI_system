# Sentio Agent - Railway Deployment
# Build context: app/Sentio/
FROM python:3.9-slim

ARG DEBIAN_FRONTEND=noninteractive
ENV TZ=Asia/Seoul

WORKDIR /app

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      tzdata build-essential curl \
 && ln -fs /usr/share/zoneinfo/$TZ /etc/localtime \
 && dpkg-reconfigure -f noninteractive tzdata \
 && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir --upgrade pip setuptools wheel

# Pin numpy/scipy BEFORE torch so they are not upgraded
RUN pip install --no-cache-dir \
    numpy==1.26.4 \
    scipy==1.11.4

# CPU-only PyTorch
RUN pip install --no-cache-dir torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cpu

RUN pip install --no-cache-dir \
    numpy==1.26.4 \
    scipy==1.11.4 \
    pandas==2.1.1 \
    scikit-learn==1.3.2 \
    transformers>=4.30.0 \
    tokenizers>=0.13.0 \
    openai>=1.0.0 \
    flask>=2.3.0 \
    flask-cors>=4.0.0 \
    python-dotenv>=1.0.0 \
    requests>=2.31.0 \
    matplotlib>=3.5.0 \
    seaborn>=0.11.0

COPY . .

RUN mkdir -p cache logs temp models uploads results

ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1
# OPENAI_API_KEY → set in Railway dashboard

EXPOSE 5004

CMD ["python", "run_sentio_server.py"]
