# Integration Agent - Railway Deployment
# Build context: app/Integration/
FROM python:3.9-slim

ARG DEBIAN_FRONTEND=noninteractive
ENV TZ=Asia/Seoul

WORKDIR /app

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      tzdata build-essential curl \
 && ln -fs /usr/share/zoneinfo/$TZ /etc/localtime \
 && dpkg-reconfigure -f noninteractive tzdata \
 && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir --upgrade pip setuptools wheel

RUN pip install --no-cache-dir \
    numpy==1.24.3 \
    pandas==2.1.1 \
    scikit-learn==1.3.0 \
    optuna>=3.0.0 \
    openai>=1.0.0 \
    flask>=2.3.0 \
    flask-cors>=4.0.0 \
    python-dotenv>=1.0.0 \
    requests>=2.31.0 \
    joblib>=1.3.0 \
    matplotlib>=3.5.0 \
    seaborn>=0.11.0 \
    plotly>=5.15.0 \
    openpyxl>=3.1.0

COPY . .

RUN mkdir -p results cache logs temp uploads

ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1
# OPENAI_API_KEY → set in Railway dashboard

EXPOSE 5007

CMD ["python", "run_integration_server.py"]
