# Structura Agent - Railway Deployment
# Build context: app/Structura/
FROM python:3.9-slim

ARG DEBIAN_FRONTEND=noninteractive
ENV TZ=Asia/Seoul

WORKDIR /app

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      tzdata build-essential libopenblas-dev curl \
 && ln -fs /usr/share/zoneinfo/$TZ /etc/localtime \
 && dpkg-reconfigure -f noninteractive tzdata \
 && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir --upgrade pip setuptools wheel

RUN pip install --no-cache-dir \
    numpy==1.26.4 \
    scipy==1.11.4 \
    pandas==2.1.1 \
    scikit-learn==1.3.2 \
    xgboost==1.7.6 \
    shap==0.43.0 \
    lime>=0.2.0.1 \
    imbalanced-learn==0.11.0 \
    flask>=2.3.0 \
    flask-cors>=4.0.0 \
    python-dotenv>=1.0.0 \
    requests>=2.31.0 \
    joblib>=1.3.0 \
    matplotlib>=3.5.0 \
    seaborn>=0.11.0 \
    optuna==3.6.1

COPY . .

RUN mkdir -p models cache logs temp uploads results /uploads/Structura/batch /uploads/Structura/post

ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1

ENV PORT=5001
EXPOSE 5001

CMD ["python", "run_structura_server.py"]
