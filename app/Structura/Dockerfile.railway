# Structura Agent - Railway Deployment
# Build context: app/Structura/
FROM python:3.9-slim

ARG DEBIAN_FRONTEND=noninteractive
ENV TZ=Asia/Seoul

WORKDIR /app

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      tzdata build-essential libopenblas-dev curl \
 && ln -fs /usr/share/zoneinfo/$TZ /etc/localtime \
 && dpkg-reconfigure -f noninteractive tzdata \
 && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir --upgrade pip setuptools wheel

RUN pip install --no-cache-dir \
    numpy==1.24.3 \
    pandas==2.1.1 \
    scikit-learn==1.3.0 \
    xgboost>=1.6.0 \
    shap>=0.42.0 \
    lime>=0.2.0.1 \
    imbalanced-learn>=0.10.0 \
    flask>=2.3.0 \
    flask-cors>=4.0.0 \
    python-dotenv>=1.0.0 \
    requests>=2.31.0 \
    joblib>=1.3.0 \
    matplotlib>=3.5.0 \
    seaborn>=0.11.0 \
    optuna>=3.0.0

COPY . .

RUN mkdir -p models cache logs temp uploads results

ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1

EXPOSE 5001

CMD ["python", "run_structura_server.py"]
