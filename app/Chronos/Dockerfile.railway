# Chronos Agent - Railway Deployment (CPU only, no CUDA)
# Build context: app/Chronos/
FROM python:3.9-slim

ARG DEBIAN_FRONTEND=noninteractive
ENV TZ=Asia/Seoul

WORKDIR /app

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      tzdata build-essential curl \
 && ln -fs /usr/share/zoneinfo/$TZ /etc/localtime \
 && dpkg-reconfigure -f noninteractive tzdata \
 && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir --upgrade pip setuptools wheel

# Pin numpy/scipy BEFORE torch so they are not upgraded
RUN pip install --no-cache-dir \
    numpy==1.26.4 \
    scipy==1.11.4

# CPU-only PyTorch (Railway has no GPU)
RUN pip install --no-cache-dir torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cpu

RUN pip install --no-cache-dir \
    numpy==1.26.4 \
    scipy==1.11.4 \
    pandas==2.1.1 \
    scikit-learn==1.3.2 \
    statsmodels==0.14.1 \
    flask>=2.3.0 \
    flask-cors>=4.0.0 \
    python-dotenv>=1.0.0 \
    requests>=2.31.0 \
    joblib>=1.3.0 \
    matplotlib>=3.5.0 \
    seaborn>=0.11.0 \
    optuna==3.6.1 \
    tqdm>=4.64.0 \
    plotly>=5.15.0

COPY . .

RUN mkdir -p models cache logs temp uploads results /uploads/Chronos /uploads/Chronos/post /uploads/Chronos/batch

ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1

EXPOSE 5003

CMD ["python", "run_chronos_server.py"]
