# Dashboard - Railway Deployment
# Uses runtime env injection to avoid baking URLs into build
# Build context: Dashboard/

# Stage 1: Build React app with placeholder values
FROM node:18-alpine AS build

WORKDIR /app

COPY package*.json ./
RUN npm install --legacy-peer-deps

COPY . .

# Placeholder values get replaced at runtime by docker-entrypoint.sh
ENV REACT_APP_API_BASE_URL=PLACEHOLDER_SUPERVISOR_URL
ENV REACT_APP_SUPERVISOR_URL=PLACEHOLDER_SUPERVISOR_URL
ENV REACT_APP_STRUCTURA_URL=PLACEHOLDER_STRUCTURA_URL
ENV REACT_APP_COGNITA_URL=PLACEHOLDER_COGNITA_URL
ENV REACT_APP_CHRONOS_URL=PLACEHOLDER_CHRONOS_URL
ENV REACT_APP_SENTIO_URL=PLACEHOLDER_SENTIO_URL
ENV REACT_APP_AGORA_URL=PLACEHOLDER_AGORA_URL
ENV REACT_APP_INTEGRATION_URL=PLACEHOLDER_INTEGRATION_URL

RUN npm run build

# Stage 2: Serve with Nginx
FROM nginx:alpine

COPY nginx.railway.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/build /usr/share/nginx/html
COPY docker-entrypoint.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh

EXPOSE 80

ENTRYPOINT ["/docker-entrypoint.sh"]
CMD ["nginx", "-g", "daemon off;"]
